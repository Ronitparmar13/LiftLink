# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/liftlink?retryWrites=true&w=majority

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# Auth
ALLOWED_EMAIL_DOMAIN=paruluniversity.ac.in

# Geo Matching
GEO_MATCH_RADIUS_METERS=500

# Pricing
FUEL_SPLIT_RATE_PER_KM=3.5

# CORS - Set to your production frontend URL
CORS_ORIGINS=http://localhost:5173

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Production Example:
# CORS_ORIGINS=https://liftlink.vercel.app,https://liftlink.yourdomain.com
# MONGODB_URI=mongodb+srv://admin:secret@cluster0.abc.mongodb.net/liftlink?retryWrites=true&w=majority
