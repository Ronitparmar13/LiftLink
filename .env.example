# =============================================================================
# LiftLink — Environment Variables Reference
# Copy to backend/.env and frontend/.env (see README.md)
# =============================================================================

# --- Backend (backend/.env) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/liftlink?retryWrites=true&w=majority
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json
ALLOWED_EMAIL_DOMAIN=paruluniversity.ac.in
GEO_MATCH_RADIUS_METERS=500
FUEL_SPLIT_RATE_PER_KM=3.5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend (frontend/.env) — must use VITE_ prefix ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
